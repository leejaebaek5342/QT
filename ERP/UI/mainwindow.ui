    <property name="styleSheet">
     <string notr="true">QWidget {
    background-color: #eef1f4;
    color: #222222;
    font-family: Arial;
    font-size: 13px;
}
QFrame#summaryCard1, QFrame#summaryCard2, QFrame#summaryCard3, QFrame#summaryCard4,
QFrame#inventoryCard, QFrame#logCard {
    background-color: #ffffff;
    border: 1px solid #d6dbe0;
    border-radius: 6px;
}
QTableWidget {
    background-color: #eef1f4;
    gridline-color: #cfd5dc;
    border: 1px solid #9fa7b0;
    selection-background-color: #dcecff;
    selection-color: #222222;
}
QTableWidget::viewport {
    background-color: #eef1f4;
}
QHeaderView::section {
    background-color: #f3f5f8;
    border: 1px solid #cfd5dc;
    color: #0070b8;
    font-weight: bold;
    padding: 6px;
}
QPushButton {
    background-color: #f7f8fa;
    color: #222222;
    border: 1px solid #b8c0c8;
    border-radius: 4px;
    padding: 8px 22px;
}</string>
